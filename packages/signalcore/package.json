{
  "name": "@buildsignal/signalcore",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "build": "esbuild src/index.ts --bundle --format=esm --outdir=dist --platform=neutral --target=es2022",
    "typecheck": "tsc -b --pretty false",
    "lint": "eslint src/ --ext .ts",
    "deploy": "wrangler deploy --env production",
    "deploy:preview": "wrangler deploy --env preview"
  },
  "dependencies": {
    "hono": "^4.8.3",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250408.0",
    "esbuild": "^0.27.2",
    "typescript": "~5.9.3"
  }
}
