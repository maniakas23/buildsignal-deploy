{
  "name": "@buildsignal/api",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "./src/app.ts",
  "scripts": {
    "dev": "wrangler dev",
    "build": "esbuild src/boot.ts --platform=node --bundle --format=esm --outdir=dist --banner:js=\"import { createRequire } from 'module';const require = createRequire(import.meta.url);\"",
    "typecheck": "tsc -b --pretty false",
    "lint": "eslint src/ --ext .ts",
    "deploy": "wrangler deploy --env production",
    "deploy:preview": "wrangler deploy --env preview",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push"
  },
  "dependencies": {
    "@hono/node-server": "^1.14.3",
    "@planetscale/database": "^1.20.1",
    "cookie": "^1.1.1",
    "dotenv": "^17.2.3",
    "drizzle-orm": "^0.45.1",
    "hono": "^4.8.3",
    "hono-rate-limiter": "^0.5.3",
    "jose": "6.1.3",
    "stripe": "^22.3.2",
    "superjson": "^2.2.6",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250408.0",
    "drizzle-kit": "^0.31.8",
    "esbuild": "^0.27.2",
    "typescript": "~5.9.3"
  }
}
