# BuildSignal Frontend — Production Environment Variables
# These VITE_ prefixed variables are baked into the build at compile time.
# Backend secrets must NEVER be added here — they belong in the API Worker.

# BuildSignal API — The separated backend Worker
VITE_API_URL=https://api.buildsignal.net

# Kestovar Engine API — Separate Worker for intelligence
VITE_SIGNALCORE_API_URL=https://api.kestovar.buildsignal.com
VITE_SIGNALCORE_WS_URL=wss://ws.kestovar.buildsignal.com

# Kimi OAuth — Required for authentication
# Set these to your Kimi platform app credentials
VITE_KIMI_AUTH_URL=https://kimi-auth-url.example.com
VITE_APP_ID=your-kimi-app-id

# Application Mode
VITE_APP_MODE=production

# Demo Mode — Disabled in production
VITE_USE_MOCK=false
