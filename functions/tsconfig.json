{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "noEmit": true,
    "allowImportingTsExtensions": true,
    "baseUrl": "..",
    "paths": {
      "@contracts/*": ["./contracts/*"],
      "@db/*": ["./db/*"],
      "@/*": ["./src/*"]
    }
  },
  "include": ["./**/*.ts", "../api/**/*.ts", "../contracts/**/*.ts", "../db/**/*.ts"]
}
